# Yield Duel - Mantle Sepolia testnet
# Copy to .env.local

# On-chain (required for live duels)
NEXT_PUBLIC_YIELD_DUEL_CONTRACT=
DEPLOYER_PRIVATE_KEY=

# Optional: verify contract on https://sepolia.mantlescan.xyz after deploy
# Standard Etherscan API key from https://etherscan.io/myapikey works (chain 5003)
ETHERSCAN_API_KEY=

# Groq: smarter agent reasoning (falls back to rules if empty)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# MongoDB: duel history + live leaderboard (falls back to demo data if empty)
MONGODB_URI=
MONGODB_DB_NAME=yield-duel